#!/bin/sh
# arc-builder-managed-hook:v1
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

python_cmd=
for candidate in python3 python; do
  if command -v "$candidate" >/dev/null 2>&1 \
    && "$candidate" -c 'import sys; raise SystemExit(sys.version_info < (3, 10))' >/dev/null 2>&1; then
    python_cmd=$candidate
    break
  fi
done

if [ -z "$python_cmd" ]; then
  echo "pre-commit guard: Python 3 is required" >&2
  exit 1
fi

"$python_cmd" scripts/pre_commit_guard.py
"$python_cmd" scripts/scan_for_secrets.py
