# Arc MCP Builder Assistant safe local defaults.
# Copy this file to .env only for local experiments. Do not commit .env.
# Store real API keys, verifier tokens, or payment proofs in a secret manager.

# Local x402 challenge server demo. These values are safe placeholders and
# keep the example Arc Testnet only, human-approved, and non-settling.
X402_DEMO_NETWORK=arc-testnet
X402_DEMO_ASSET=USDC
X402_DEMO_AMOUNT=0.01
X402_DEMO_PAY_TO=0xA11CE00000000000000000000000000000000000
X402_DEMO_MAINNET_ENABLED=false

# Optional challenge-only smoke for a deployed paid-agent endpoint.
# The smoke script first validates the unpaid 402 response and never creates
# payments by itself.
ARC_PAID_AGENT_URL=
EXPECT_402_ONLY=true

# Optional externally created payment proof for a paid retry smoke.
# Keep real proof values out of the repo.
ARC_LIVE_X_PAYMENT=

# Future production verifier placeholders. Leave empty in public code.
CIRCLE_GATEWAY_API_KEY=
X402_GATEWAY_VERIFIER_URL=
